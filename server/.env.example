# Backend environment variables - copy to .env
PORT=8080
DB_NAME=ieltstar
DB_URL=mongodb://localhost:27017
DB_USER=
DB_PASS=

# SendGrid email (optional)
SENDGRID_APIKEY=your_sendgrid_key
FROM_EMAIL=noreply@example.com
SENDGRID_TEMPLATEID=your_template_id

# Twilio SMS (optional)
AccountSID=your_twilio_sid
AuthToken=your_twilio_token
FROM_SMS=+1234567890
